{
  "name": "crowdsense-ai",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "CrowdSense AI — Tactical crowd intelligence platform powered by Gemini 2.5 Flash",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --ci --forceExit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/ frontend/js/",
    "format:check": "prettier --check src/ frontend/js/",
    "docs": "jsdoc src/ frontend/js/ -r -d docs/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "@jest/globals": "30.3.0",
    "compression": "1.8.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "helmet": "8.1.0",
    "joi": "^18.1.2",
    "morgan": "1.10.1",
    "multer": "^2.1.1",
    "validator": "^13.15.35",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "depcheck": "1.4.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdoc": "^4.0.5",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "21.0.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
